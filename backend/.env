# Redis
REDIS_URL=redis://localhost:6379/0

# Local outputs
OUTPUT_DIR=./outputs
CLONE_DIR=./clones

# Limits
REPO_MAX_MB=50
REPO_MAX_FILES=1000
IMPORTANT_FILES_MAX=20
ANALYSIS_TIMEOUT_SEC=300
CACHE_TTL_SEC=86400

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SEC=60